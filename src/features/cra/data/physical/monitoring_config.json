    "review_freq": "Monthly (Nov-Mar)",
    "data_source": "IQAir / NIMET Dust Forecast",
    "owner_role": "Facilities Manager",
    "owner_name": "[Insert Name]"
  },
  "Heavy Rainfall": {
    "kpi": "Monthly rainfall total vs drainage capacity threshold",
