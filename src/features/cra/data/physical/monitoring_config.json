    "review_freq": "Monthly during rainy season",
    "data_source": "NIMET / CHIRPS",
    "owner_role": "Facilities Manager",
    "owner_name": "[Insert Name]"
  },
  "River Flooding": {
    "kpi": "River level at nearest gauge (metres above datum)",
